{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "data/**",
      "maxDuration": 300
    },
    "api/[...path].ts": {
      "includeFiles": "data/**",
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
